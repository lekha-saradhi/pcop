# Azure AI Foundry — DeepSeek for NARRATE cycle
AZURE_FOUNDRY_ENDPOINT=https://kensara.services.ai.azure.com/models
AZURE_API_KEY=your_azure_api_key
NARRATE_MODEL=DeepSeek-V3

# Database
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/pcop

# ClickHouse (analytical store)
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_DB=pcop_analytics

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=pcop_chronos_retrain

# Demo mode
ORACLE_DEMO_MODE=true

# Bandit settings
PROMPT_UPLIFT_THRESHOLD=0.02
AB_MIN_DISPATCHES=100
AB_SIGNIFICANCE_LEVEL=0.05
