# Database
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/pcop

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ClickHouse (for analytical reads)
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_DB=pcop_analytics

# Demo mode (true = simulate events, no real DB/Kafka)
VERDICT_DEMO_MODE=true

# Holdout
HOLDOUT_FRACTION=0.15
HOLDOUT_RESCUE_THRESHOLD=0.92
MAX_HOLDOUT_DAYS=30

# DR attribution
DR_MIN_SAMPLES=50
DR_UPLIFT_THRESHOLD=0.02
