# Azure AI Foundry
AZURE_FOUNDRY_ENDPOINT=https://YOUR_RESOURCE.services.ai.azure.com/models
AZURE_FOUNDRY_KEY=your_azure_foundry_api_key

# Model names (as registered in Azure Foundry catalog)
COGNITION_MODEL=kimi-k2-6-thinking
COMPASS_MODEL=kimi-k2-5

# LangGraph / LangSmith
LANGGRAPH_TRACING=true
LANGSMITH_API_KEY=your_langsmith_key
LANGSMITH_PROJECT=pcop-compass

# Compass behaviour
COMPASS_DEMO_MODE=true
COMPASS_MAX_TOOL_ROUNDS_COGNITION=5
COMPASS_MAX_TOOL_ROUNDS_NBA=3
COMPASS_RESCUE_THRESHOLD=0.92
COMPASS_FATIGUE_LIMIT_30D=4

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/pcop

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Redis
REDIS_URL=redis://localhost:6379/0
