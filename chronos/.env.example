# CHRONOS Scoring Service Environment Variables
# Copy to .env and fill in values — NEVER commit .env to git

# Database
DATABASE_URL=postgresql://pcop:pcop_dev@localhost:5432/pcop
POSTGRES_USER=pcop
POSTGRES_PASSWORD=pcop_dev
POSTGRES_DB=pcop

# Redis
REDIS_URL=redis://localhost:6379

# Kafka
KAFKA_BROKERS=localhost:9092

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000

# Model paths (override defaults)
# TARE_ONNX_PATH=ml/checkpoints/tare_churn.onnx
# HABITAT_MODEL_PATH=ml/checkpoints/habitat_pass1.json
# GENESIS_MODEL_PATH=ml/checkpoints/genesis_lr.pkl
# AEGIS_STATS_PATH=ml/checkpoints/aegis_reference.json

# Kaggle (for dataset download)
# KAGGLE_USERNAME=your_username
# KAGGLE_KEY=your_api_key
