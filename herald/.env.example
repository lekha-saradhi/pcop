# Azure AI Foundry — DeepSeek via Azure AI Inference (/models endpoint)
AZURE_FOUNDRY_ENDPOINT=https://kensara.services.ai.azure.com/models
AZURE_API_KEY=your_azure_api_key
SCRIBE_MODEL=DeepSeek-V3

# Database
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/pcop

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Demo mode (true = log only, don't send)
HERALD_DEMO_MODE=true

# SendGrid
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=outreach@yourbank.com

# Twilio
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_FROM_NUMBER=+91XXXXXXXXXX

# Firebase FCM
FCM_SERVER_KEY=your_fcm_server_key
FCM_PROJECT_ID=your_firebase_project_id

# RM Task Queue
RM_TASK_QUEUE_URL=http://internal-rm-queue/api
RM_API_KEY=your_rm_api_key

# Compliance
HERALD_MAX_COMPLIANCE_RETRIES=2
